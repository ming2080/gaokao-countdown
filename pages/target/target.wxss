/* pages/target/target.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.card-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #4A90D9;
  padding: 8rpx 16rpx;
}

.action-btn.danger {
  color: #FF6B6B;
}

/* 目标展示 */
.target-content {
  text-align: center;
  padding: 40rpx 0;
}

.target-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.university-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #4A90D9;
}

.target-score-text {
  font-size: 28rpx;
  color: #999999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 编辑表单 */
.edit-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
}

.form-input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.form-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.select-btn {
  padding: 16rpx 24rpx;
  background-color: #4A90D9;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 26rpx;
}

/* 分差显示 */
.score-gap {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-radius: 12rpx;
}

.gap-label {
  font-size: 28rpx;
  color: #666666;
}

.gap-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF6B6B;
  font-family: 'DIN Alternate', 'Arial', sans-serif;
}

.gap-unit {
  font-size: 28rpx;
  color: #FF6B6B;
}

/* 表单按钮 */
.form-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #f5f5f5;
  color: #666666;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}

.btn-primary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}

/* 分数分析 */
.tips-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.tip-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 28rpx;
  color: #666666;
  flex: 1;
}

/* 大学列表 */
.university-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.uni-item {
  width: calc(50% - 8rpx);
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  text-align: center;
}

.uni-name {
  font-size: 26rpx;
  color: #333333;
}
